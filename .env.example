# ── EventBday (Open-Source) — variáveis de ambiente ──────────
# Copie este arquivo para .env.local e preencha com seus valores.
# Nenhuma chave de serviço de terceiros é necessária.

# String de conexão do seu PostgreSQL (local, Supabase, Railway, Neon, etc.)
DATABASE_URL=postgres://usuario:senha@localhost:5432/eventbday

# Chave de administração desta instância (acesso à área /admin).
# Defina um valor longo e secreto — gere com: openssl rand -hex 32
ADMIN_TOKEN=troque-por-uma-chave-secreta-longa

# URL pública da instância — usada para montar os links de convite.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
